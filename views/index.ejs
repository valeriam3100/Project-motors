<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/header') %>
    <%- include('partials/navigation') %>
    <main>
      <section>
        <div class="main-content">
          <h1>Welcome to CSE Motors!</h1>
          <div class="delorean-info">
            <h2>DMC Delorean</h2>
            <ul>
              <li>3 Cup holders</li>
              <li>Superman doors</li>
              <li>Fuzzy dice!</li>
            </ul>
            <a href="#" class="btn">Own Today</a>
          </div>
          <div class="delorean-image">
          <img src="/images/delorean.png" alt="DMC Delorean">
        </div>
        </div>
      </section>
      <section class="upgrades-reviews">
        <div class="upgrades">
          <h3>Delorean Upgrades</h3>
          <div class="upgrade-grid">
          <div class="upgrade-item">
            <figure>
            <img src="/images/flux-capacitor.png" alt="Flux Capacitor">
            <figcaption><a href="#">Flux Capacitor</a></figcaption>
          </figure>
          </div>
          <div class="upgrade-item">
            <figure>
            <img src="/images/flame-decals.png" alt="Flame Decals">
            <figcaption><a href="#">Flame Decals</a></figcaption>
          </figure>
          </div>
          <div class="upgrade-item">
            <figure>
            <img src="/images/bumper-stickers.png" alt="Bumper Stickers">
            <figcaption><a href="#">Bumper Stickers</a></figcaption>
          </figure>
          </div>
          <div class="upgrade-item">
            <figure>
            <img src="/images/hub-caps.png" alt="Hub Caps">
           <figcaption><a href="#">Hub Caps</a></figcaption> 
          </figure>
          </div>
        </div>
      </div>
        <div class="reviews">
          <h3>DMC Delorean Reviews</h3>
          <ul>
            <li>“So fast it's almost like traveling in time.” (4/5)</li>
            <li>“Coolest ride on the road.” (4.5/5)</li>
            <li>“I'm feeling McFly!” (5/5)</li>
            <li>“The most futuristic ride of our day.” (4.5/5)</li>
            <li>“80's livin and I love it!” (5/5)</li>
          </ul>
        </div>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
